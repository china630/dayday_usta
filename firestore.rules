rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // ПОМОЩНИКИ
    // -------------------------------------------------------------------------
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isClient() {
      return request.auth != null && getProfile() != null && getProfile().role == 'client';
    }
    function isMaster() {
      return request.auth != null && getProfile() != null && getProfile().role == 'master';
    }
    function isAdmin() {
      return request.auth != null && getProfile() != null && getProfile().role == 'admin';
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isFormerOrderMaster(order) {
      let fm = order.formerMasterIds;
      return fm is list && fm.hasAny([request.auth.uid]);
    }

    // -------------------------------------------------------------------------
    // ✅ ПУБЛИЧНЫЕ СПРАВОЧНИКИ
    // -------------------------------------------------------------------------
    match /categories/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /districts/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Агрегаты UX (среднее время accept по категории) — только сервер
    match /category_metrics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // ✅ ТРАНЗАКЦИИ (ИСТОРИЯ ПЛАТЕЖЕЙ) - НОВОЕ!
    // -------------------------------------------------------------------------
    match /transactions/{transactionId} {
      // Читать: Только свои чеки
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Писать: ЗАПРЕЩЕНО (пишет только сервер)
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // КОЛЛЕКЦИЯ USERS (ПРОФИЛИ)
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if (
        isOwner(userId) ||
        isAdmin() ||
        (isClient() && resource.data.role == 'master' && resource.data.verificationStatus == 'verified') ||
        (isMaster() && resource.data.role == 'client')
      );
      allow create: if (
        isOwner(userId) && (!exists(/databases/$(database)/documents/users/$(userId)))
      );
      allow update: if (
        isOwner(userId) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid'])) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['favoriteMasterIds']) || resource.data.role == 'client') &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'rating', 'callsCount', 'viewsCount', 'verificationStatus',
          'balance', 'frozenBalance',
          'consecutiveRejections', 'probationEndsAt', 'banExpiresAt', 'lastBlockedAt'
        ]))
      );
      allow delete: if (isAdmin());
    }

    // -------------------------------------------------------------------------
    // КОЛЛЕКЦИЯ ORDERS (ЗАКАЗЫ)
    // -------------------------------------------------------------------------
    match /orders/{orderId} {
      allow read: if
          isAdmin() ||
          isOwner(resource.data.customerId) ||
          (isMaster() && (
             resource.data.masterId == request.auth.uid ||
             resource.data.targetMasterId == request.auth.uid ||
             resource.data.status == 'pending' ||
             isFormerOrderMaster(resource.data)
          ));
      // Yaradılması yalnız Cloud Functions (Admin SDK) ilə; birbaşa klient yazısı bağlıdır
      allow create: if false;
      // Birbaşa status/balance dəyişiklikləri yalnız CF; müştəri yalnız rəy sonrası isReviewed yaza bilər
      allow update: if isAdmin() || (
          isOwner(resource.data.customerId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isReviewed'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId}/events/{eventId} {
      function orderDoc() {
        return get(/databases/$(database)/documents/orders/$(orderId)).data;
      }
      function canReadOrderEvents() {
        let o = orderDoc();
        return isAdmin() ||
          o.customerId == request.auth.uid ||
          o.masterId == request.auth.uid ||
          o.targetMasterId == request.auth.uid ||
          isFormerOrderMaster(o);
      }
      allow read: if request.auth != null && canReadOrderEvents();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // КОЛЛЕКЦИЯ REVIEWS (ОТЗЫВЫ)
    // -------------------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if (request.auth != null);
      allow create: if (isClient());
      allow update, delete: if (isAdmin());
    }

    // -------------------------------------------------------------------------
    // КОЛЛЕКЦИЯ MESSAGES (ЧАТ)
    // -------------------------------------------------------------------------
    match /orders/{orderId}/messages/{messageId} {
      function canAccessChat() {
        let order = get(/databases/$(database)/documents/orders/$(orderId)).data;
        let fm = order.formerMasterIds;
        let wasFormer = fm is list && fm.hasAny([request.auth.uid]);
        return isAdmin() || isOwner(order.customerId) || (isMaster() && order.masterId == request.auth.uid) || wasFormer;
      }
      allow read: if (canAccessChat());
      allow create: if (canAccessChat());
      allow update, delete: if (false);
    }

    // -------------------------------------------------------------------------
    // КОЛЛЕКЦИЯ master_filters
    // -------------------------------------------------------------------------
    match /master_filters/{docId} {
      allow read: if (request.auth != null);
      allow write: if (isAdmin() || isMaster());
    }
    match /{path=**}/categories_index/{filterId} {
      allow read: if request.auth != null;
    }
    match /{path=**}/districts_index/{filterId} {
      allow read: if request.auth != null;
    }

    // -------------------------------------------------------------------------
    // СИСТЕМНЫЕ НАСТРОЙКИ (ТАРИФЫ)
    // -------------------------------------------------------------------------
    match /system_settings/{docId} {
      allow read: if true; // Чтобы приложение знало цену
      allow write: if false;
    }

  }
}